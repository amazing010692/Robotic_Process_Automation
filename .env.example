# =============================================================================
# UiPath RPA Project - Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# UiPath Orchestrator Connection (for CI/CD deployment)
UIPATH_ORCHESTRATOR_URL=https://cloud.uipath.com/your-org/your-tenant
UIPATH_ORCHESTRATOR_TENANT=<your-tenant-name>
UIPATH_ORCHESTRATOR_FOLDER=<your-folder-name>

# Authentication (use one method)
UIPATH_CLIENT_ID=<your-client-id>
UIPATH_CLIENT_SECRET=<your-client-secret>

# Robot Configuration
UIPATH_ROBOT_NAME=<robot-name>
UIPATH_ENVIRONMENT=Development

# Application URLs (used by web automation robots)
CRM_WEB_URL=https://your-crm-instance.example.com
RPA_CHALLENGE_URL=https://rpachallenge.com

# File Paths (override defaults if needed)
INPUT_FOLDER_PATH=./data/input
OUTPUT_FOLDER_PATH=./data/output
