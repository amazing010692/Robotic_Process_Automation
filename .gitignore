# =============================================================================
# UiPath RPA Project - .gitignore
# =============================================================================

# UiPath Local Cache & Build Artifacts
**/.local/
**/.objects/
**/.tmh/

# UiPath Settings (machine-specific)
**/.settings/

# NuGet packages
**/packages/

# Debug logs
**/debug.log

# Output files (generated at runtime)
**/output/

# Screenshots (auto-generated by UiPath recorder)
**/.screenshots/

# Compiled packages
**/*.nupkg

# =============================================================================
# OS Generated Files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# =============================================================================
# IDE & Editor Files
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.log
